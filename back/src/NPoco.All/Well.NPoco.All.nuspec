  <metadata>
    <id>Well.NPoco.All</id>
    <version>6.2.4</version>
    <title>Well.NPoco.All</title>
    <authors>Adam Schröder</authors>
    <owners>Adam Schröder</owners>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <projectUrl>https://github.com/tozwei/NPoco</projectUrl>
    <description>An extremely easy to use Micro-ORM supporting Sql Server, MySQL, PostgreSQL, Oracle, Sqlite, SqlCE. This package includes all NPoco components: NPoco, NPoco.Abstractions, NPoco.SqlServer, NPoco.SqlServer.SystemData, and NPoco.JsonNet.</description>
    <releaseNotes>https://github.com/schotime/NPoco/wiki/Release-Notes</releaseNotes>
    <tags>orm;sql;micro-orm;database;mvc</tags>
  </metadata>
